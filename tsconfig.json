{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "paths": {
      "@toolhub/shared": ["./packages/shared/src/index.ts"],
      "@shared/*": ["./packages/shared/src/*"],
      "@/*": ["./src/*"]
    }
  },
  "include": ["src", "electron", "packages/shared/src", "scripts"],
  "exclude": ["node_modules", "dist", "dist-electron", "out"]
}
